# ============================================================
# AarogyaGuruji - Environment Variables Example
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to git!
# ============================================================

# --- Google Blogger API ---
# Get from client_secret.json
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Run generate_token.py once to get this:
GOOGLE_REFRESH_TOKEN=your_refresh_token_here

# Your Blogger Blog ID
BLOG_ID=707690830658262263

# --- Gemini AI API ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Groq AI API (Fallback) ---
GROQ_API_KEY=your_groq_api_key_here

# --- Pexels API (for images) ---
PEXELS_API_KEY=your_pexels_api_key_here

# --- NewsData.io API (for trending health news) ---
NEWSDATA_API_KEY=your_newsdata_api_key_here

# --- Optional: Number of articles per run (default 7) ---
ARTICLES_PER_RUN=7
